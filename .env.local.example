# Copy this file to .env.local (local dev) and add the same variables in
# Vercel → Project → Settings → Environment Variables (Production + Preview).
#
# Used by app/api/contact/route.ts to send the contact form via SMTP.

# REQUIRED — the Gmail account that sends the mail
SMTP_USER=sigibau6@gmail.com

# REQUIRED — a Google "App Password" (16 characters, no spaces).
# Create it at: https://myaccount.google.com/apppasswords
# (2-Step Verification must be enabled on the Google account first.)
SMTP_PASS=your_16_char_app_password

# OPTIONAL — defaults shown; only change for a non-Gmail provider
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465

# OPTIONAL — where submissions are delivered (defaults to sigibau6@gmail.com)
CONTACT_TO=sigibau6@gmail.com
